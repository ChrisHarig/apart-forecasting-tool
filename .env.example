# Frontend env vars. Vite only exposes vars prefixed with VITE_.

# Optional: only required if EPI-Eval datasets are private on Huggingface.
# Public datasets work without auth.
# VITE_HF_TOKEN=hf_...

# Optional: override the MapLibre style URL.
# VITE_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
